<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Interior Admin Page</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>

<body>
    <div>
        <div class="header">
            <h1>U.M INTERIORS - Admin Panel </h1>
            <h2>
                Welcome <%= user ? user.name : 'Guest' %>
            </h2>
            <ul>
                <li><a href="/" class="<%= url === '/' ? 'active' : '' %>">Home</a></li>

                <% if (user) { %>
                    <li><a href="/interiors" class="<%= url === '/interiors' ? 'active' : '' %>">Interiors</a></li>
                    <li><a href="/users" class="<%= url === '/users' ? 'active' : '' %>">Users</a></li>
                    <li><a href="/auth/logout">Logout</a></li>
                    <% } else { %>
                        <li><a href="/auth/login" class="<%= url === '/auth/login' ? 'active' : '' %>">Login</a></li>
                        <% } %>
            </ul>
        </div>
        <div><%- body %></div>
        <div class="footer">&copy; 2026. All rights reserved.</div>
    </div>
</body>

</html>