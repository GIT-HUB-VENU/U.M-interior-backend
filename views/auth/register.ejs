<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

    <div class="register-page">


        <form class="register-form" action="/auth/register" method="POST">
            <h2 class="register-title">Registration Form</h2>
            <p><input class="register-input" type="text" name="name" placeholder="Name"></p>
            <p><input class="register-input" type="text" name="email" placeholder="Email"></p>
            <p><input class="register-input" type="password" name="password" placeholder="Password"></p>
            <p><button class="register-btn">Submit</button></p>
            <p class="register-login-link">
                <a href="/auth/login">Already a member? Login here</a>
            </p>
        </form>


    </div>

</body>

</html>