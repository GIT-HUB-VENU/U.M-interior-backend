<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document</title>
</head>

<body>
  <h1>Interiors Page</h1>
  <div class="row">
    <% interiors.forEach(interior=> { %>
      <div class="box">
        <img src="<%= interior.image %>" width="300px" alt="Interior 1">
        <h2>
          <%= interior.name %>
        </h2>
        <p>
          <%= interior.desc %>
        </p>
        <h4>
          <%= interior.price %>
        </h4>
      </div>
      <% }) %>
  </div>
</body>

</html>